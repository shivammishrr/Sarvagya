# Copy to .env and fill in required keys
OPENAI_API_KEY=
TAVILY_API_KEY=
# Model settings (defaults to OpenAI dynamic alias)
MODEL_NAME=chatgpt-4o-latest
# LLM Provider selection: openai|anthropic|gemini|mistral|groq
LLM_PROVIDER=openai
# Anthropic
ANTHROPIC_API_KEY=
# Google Gemini
GOOGLE_API_KEY=
# Mistral
MISTRAL_API_KEY=
# Groq
GROQ_API_KEY=
# Server
APP_HOST=0.0.0.0
APP_PORT=8000
# Optional services
BROWSER_TOOL_URL=http://browser_tool:8081
PYTHON_REPL_URL=http://python_repl_tool:8082
